  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#3A812E",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword.control",
        "keyword",
        "storage"
      ],
      "settings": {
        "foreground": "#7BFF57"
      }
    },
    {
      "scope": [
        "storage.type",
        "storage.modifier",
        "keyword.operator.new"
      ],
      "settings": {
        "foreground": "#AEFF00"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#F0FFD9"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "meta.function-call",
        "variable.function",
        "support.function"
      ],
      "settings": {
        "foreground": "#FFF18A"
      }
    },
    {
      "scope": [
        "support.function.builtin",
        "support.function.builtin.python"
      ],
      "settings": {
        "foreground": "#FFCF66"
      }
    },
    {
      "scope": [
        "entity.name.decorator",
        "entity.name.function.decorator",
        "meta.function.decorator"
      ],
      "settings": {
        "foreground": "#FFB84D"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable"
      ],
      "settings": {
        "foreground": "#C2EEA0"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.function.parameters",
        "meta.parameter.object-binding"
      ],
      "settings": {
        "foreground": "#FFF4D0"
      }
    },
    {
      "scope": [
        "variable.parameter.function.language.special.self.python",
        "variable.parameter.function.language.special.cls.python",
        "variable.language.this"
      ],
      "settings": {
        "foreground": "#FFF1A8",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "meta.attribute",
        "entity.other.attribute-name",
        "support.type.property-name",
        "variable.object.property"
      ],
      "settings": {
        "foreground": "#EDB391"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.interpolated"
      ],
      "settings": {
        "foreground": "#FFFFF6"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#FFE45E"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "constant.other"
      ],
      "settings": {
        "foreground": "#D16C00"
      }
    },
    {
      "scope": [
        "constant",
        "entity.name.constant",
        "variable.language",
        "support.constant"
      ],
      "settings": {
        "foreground": "#FFF0C0"
      }
    },
    {
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.accessor",
        "punctuation.terminator.statement"
      ],
      "settings": {
        "foreground": "#EDB391"
      }
    },
    {
      "scope": [
        "punctuation.section.block.begin",
        "punctuation.section.block.end",
        "punctuation.section.group.begin",
        "punctuation.section.group.end",
        "punctuation.definition.parameters.begin",
        "punctuation.definition.parameters.end"
      ],
      "settings": {
        "foreground": "#FF8A68"
      }
    },
    {
      "scope": [
        "regexp"
      ],
      "settings": {
        "foreground": "#FFB84D"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#FFF4F4",
        "background": "#B13636"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name"
      ],
      "settings": {
        "foreground": "#FFF0C0",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#FFFFFA",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#C2EEA0",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#FFE45E"
      }
    },
    {
      "scope": [
        "markup.list",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#AEFF00"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#81BC60",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml",
        "punctuation.definition.tag"
      ],
      "settings": {
        "foreground": "#B3ED91"
      }
    },
    {
      "scope": [
        "support.type.property-name.json",
        "meta.object-literal.key",
        "meta.mapping.key"
      ],
      "settings": {
        "foreground": "#B3ED91"
      }
    },
    {
      "scope": [
        "keyword.other.unit.css",
        "constant.numeric.css",
        "constant.other.color.rgb-value.css"
      ],
      "settings": {
        "foreground": "#D16C00"
      }
    },
    {
      "scope": [
        "source.sql keyword",
        "keyword.other.DML.sql",
        "keyword.other.sql"
      ],
      "settings": {
        "foreground": "#AEFF00"
      }
    },
    {
      "scope": [
        "support.function.aggregate.sql",
        "support.function.scalar.sql"
      ],
      "settings": {
        "foreground": "#FFB84D"
      }
    },
    {
      "scope": [
        "markup.link",
        "string.other.link.title.markdown",
        "string.other.link.description.markdown"
      ],
      "settings": {
        "foreground": "#9EED91"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": "#F0FFD9",
    "class": "#F0FFD9",
    "enum": "#ECFFCE",
    "interface": "#F0FFD9",
    "struct": "#F0FFD9",
    "typeParameter": "#F6FFE7",
    "type": "#F0FFD9",
    "parameter": "#FFF4D0",
    "variable": "#C2EEA0",
    "property": "#EDB391",
    "enumMember": "#FFF0C0",
    "decorator": "#FFB84D",
    "event": "#FFF18A",
    "function": "#FFF18A",
    "method": "#FFF18A",
    "macro": "#FFCF66",
    "label": "#7BFF57",
    "comment": {
      "foreground": "#3A812E",
      "italic": true
    },
    "string": "#FFFFF6",
    "keyword": "#7BFF57",
    "number": "#FFE45E",
    "regexp": "#FFB84D",
    "operator": "#EDB391"
  }
}
